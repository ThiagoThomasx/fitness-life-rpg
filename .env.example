# Supabase — obter em: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Apenas no servidor (nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Database URL para Prisma (obter em: Project Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.seu-projeto.supabase.co:5432/postgres
