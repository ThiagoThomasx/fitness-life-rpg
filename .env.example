# Supabase — obter em: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Apenas no servidor (nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Google OAuth — obter em: Supabase → Auth → Providers → Google
# (o redirect automático é: https://seu-projeto.supabase.co/auth/v1/callback)

# App URL (sem trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
